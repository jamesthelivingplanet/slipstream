{
  "name": "slipstream",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "dist-electron/main.js",
  "engines": {
    "node": "22.x"
  },
  "description": "Desktop console for managing many parallel Claude Code agents",
  "scripts": {
    "dev": "node scripts/build-server.mjs && vite",
    "dev:backend": "node scripts/dev-backend.mjs",
    "build": "vite build && node scripts/build-server.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "serve": "ELECTRON_RUN_AS_NODE=1 electron dist-electron/server.js",
    "package": "pnpm build && electron-builder --publish never",
    "deploy": "bash scripts/deploy.sh",
    "setup": "bash scripts/setup.sh",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "better-sqlite3": "^11.7.0",
    "node-pty": "^1.0.0",
    "opencode-ai": "^1.17.11",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.1",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.20.0",
    "globals": "^17.7.0",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "prettier": "^3.9.4",
    "prettier-plugin-svelte": "^3.5.2",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "svelte-eslint-parser": "^1.8.0",
    "tailwindcss": "^3.4.15",
    "tslib": "^2.8.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^3.2.4"
  }
}
