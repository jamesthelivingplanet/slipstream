# Copy to .env (docker compose reads .env automatically) and fill in.
# .env is gitignored — keep it on the pod, never commit it.

# --- Required ---------------------------------------------------------------
# Auth token for the Slipstream WebSocket endpoint. Generate: openssl rand -hex 16
SLIPSTREAM_TOKEN=

# Your Anthropic API key — agents authenticate Claude Code with this.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Tailscale auth key (reusable or ephemeral). Create at:
# https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# --- Optional ---------------------------------------------------------------
# Machine name on your tailnet -> https://<TS_HOSTNAME>.<tailnet>.ts.net
TS_HOSTNAME=slipstream

# Git identity + push credentials for agents that open PRs.
GIT_USER_NAME=
GIT_USER_EMAIL=
# A GitHub token with `repo` scope (used for HTTPS clone + push).
GH_TOKEN=

# Contain each agent PTY in a bubblewrap mount namespace so a prompt-injected
# agent can't read the daemon's data dir (tokens, slipstream.db). Linux only;
# needs `bwrap` installed + unprivileged user namespaces. Off unless set.
# Note: disables agent-initiated `slipstream open-mr` (it needs the DB token).
SLIPSTREAM_SANDBOX=
